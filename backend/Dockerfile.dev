# Development Dockerfile for the Rails API.
# Ruby version is pinned to match backend/.ruby-version (4.0.1).
ARG RUBY_VERSION=4.0.1
FROM docker.io/library/ruby:$RUBY_VERSION-slim

# System packages needed to build native gems (pg, image_processing) and run Rails.
RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      curl \
      git \
      libpq-dev \
      libvips \
      libyaml-dev \
      postgresql-client \
      pkg-config && \
    rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

WORKDIR /rails

# Install gems first so the layer is cached when only app code changes.
COPY Gemfile Gemfile.lock ./
RUN bundle install

# App code is bind-mounted in development (see docker-compose.yml), so this COPY
# is only a fallback for running the image without a mount.
COPY . .

EXPOSE 8080

# Remove a stale server pid (if any) then boot Puma bound to all interfaces.
CMD ["bash", "-c", "rm -f tmp/pids/server.pid && bundle exec rails server -b 0.0.0.0 -p 8080"]
