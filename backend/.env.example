# Copy to backend/.env (git-ignored) and adjust as needed.
# These are consumed by config/database.yml and docker-compose.yml.

# --- Database connection ---
# For local-native Rails, leave DATABASE_HOST as localhost.
# docker-compose.yml overrides DATABASE_HOST=postgres for the rails-api container.
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=backend_development
DATABASE_TEST_NAME=backend_test

# Host port the Postgres container publishes. Change if 5432 is already taken
# on your machine (e.g. another project's Postgres). Internal port stays 5432.
POSTGRES_PUBLISHED_PORT=5432

# --- Auth ---
# Secret used to sign JWTs (devise-jwt). Falls back to secret_key_base if unset,
# which is fine for local dev; set a dedicated value in production.
DEVISE_JWT_SECRET_KEY=

# --- App ---
# ADMIN_EMAIL is used by Meklit::BatchingService for submission notifications.
ADMIN_EMAIL=admin@drivingschool.et

# Mail sender address (also used by Devise for password reset emails).
MAILER_FROM=noreply@drivingschool.et

# SMTP relay settings (used by Action Mailer in production).
# SMTP_ADDRESS=smtp.sendgrid.net

# Allowed CORS origins (comma-separated). Used by rack-cors initializer.
ALLOWED_ORIGINS=http://localhost:3000

# App hostname (used by config.hosts, proxy, and mailer URL generation).
APP_HOST=localhost:3001

# DEPLOY_SERVER_IP is used by config/deploy.yml for Kamal deployments.
# DEPLOY_SERVER_IP=203.0.113.10

# Sentry DSN for centralised error tracking. Leave blank to disable.
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@oXXXXX.ingest.sentry.io/XXXXXX

# S3 bucket for database backups (post-deploy hook).
# BACKUP_S3_BUCKET=my-backup-bucket
