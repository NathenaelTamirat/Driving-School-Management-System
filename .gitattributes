# Normalize line endings so scripts work inside Linux containers regardless of
# the OS they were checked out on. Without this, bin/* shebangs get a trailing
# CR on Windows checkouts and fail with: env: 'ruby\r': No such file or directory.

# Default: let git decide, normalizing to LF in the repo.
* text=auto eol=lf

# Executable scripts and config must always be LF (they run in the container).
backend/bin/* text eol=lf
*.sh text eol=lf
*.rb text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile* text eol=lf

# Binary assets git should never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
